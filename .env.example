# ============================================
# War Room Backend Configuration
# ============================================

# Server Port
PORT="8080"

# Database (SQLite for development, MySQL for production)
# SQLite (development): warroom.db or /path/to/warroom.db
# MySQL (production): mysql://user:password@host:port/database
DATABASE_URL="warroom.db"

# JWT Configuration
JWT_SECRET="your-secret-key-change-in-production"

# Gemini AI
GEMINI_API_KEY="your-gemini-api-key"
AI_MODEL="gemini-2.0-flash-lite-preview-02-05"

# Google Cloud Text-to-Speech (Choose ONE of the following methods for authenticating)
# Method 1 (Recommended for local dev): Path to your downloaded Service Account JSON file
GOOGLE_APPLICATION_CREDENTIALS="C:\path\to\your\service-account-key.json"

# Method 2 (Recommended for deployment/Vercel): Paste the ENTIRE contents of the JSON file on one line
GCP_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "...", ...}'

# Database Migrations (run migrations on startup)
RUN_MIGRATIONS="true"

# ============================================
# ADMIN USER (created by seed command)
# ============================================

# Admin login credentials
ADMIN_EMAIL="admin@warroom.com"
ADMIN_PASSWORD="admin123"
ADMIN_NAME="Administrator"
